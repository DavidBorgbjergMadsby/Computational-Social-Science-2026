    "\n",
    "# --- OPSÆTNING ---\n",
    "FILNAVN = \"KOMPLET_lufthavne_2001_2010.json\"\n",
    "USER_AGENT = \"DTU_Student_Project_Bot/1.4 (sXXXXXX@student.dtu.dk)\"\n",
    "# -----------------\n",
    "\n",
    "def rens_navn(navn):\n",
    "    # Fjerner fodnoter som [1], [a] og parenteser\n",
    "    navn = re.sub(r'\\(.*?\\)|\\[.*?\\]', '', str(navn)).strip()\n",
    "    return navn.replace('–', '-').replace('—', '-')\n",
    "\n",
    "def hent_tekst(session, titel, iata, aar):\n",
    "    url = \"https://en.wikipedia.org/w/api.php\"\n",
    "    # Vi prøver: 1. Navn fra tabel, 2. IATA kode\n",
    "    forsog = [titel, f\"{iata} airport\"]\n",
    "    \n",
    "    for t in forsog:\n",
    "        params = {\n",
    "            \"action\": \"query\", \"prop\": \"revisions\", \"titles\": t,\n",
    "            \"redirects\": 1, \"rvlimit\": 1, \"format\": \"json\",\n",
    "            \"rvprop\": \"content\", \"rvdir\": \"older\",\n",
    "            \"rvstart\": f\"{aar}-12-31T23:59:59Z\"\n",
    "        }\n",
    "        try:\n",
    "            r = session.get(url, params=params, timeout=10)\n",
    "            data = r.json()\n",
    "            pages = data.get(\"query\", {}).get(\"pages\", {})\n",
    "            for pid in pages:\n",
    "                if pid != \"-1\" and \"revisions\" in pages[pid]:\n",
    "                    return pages[pid][\"revisions\"][0][\"*\"]\n",
    "        except:\n",
    "            continue\n",
    "        time.sleep(0.1) # Lille pause mellem hvert forsøg\n",
    "    return \"\"\n",
    "\n",
    "# 1. Hent listen fra Wikipedia\n",
    "print(\"Henter lufthavnsliste...\")\n",
    "headers = {\"User-Agent\": \"Mozilla/5.0\"}\n",
    "r_main = requests.get(\"https://en.wikipedia.org/wiki/List_of_airports_in_the_United_States\", headers=headers)\n",
    "df = pd.read_html(r_main.text, match=\"IATA\")[0].dropna(subset=['IATA'])\n",
    "\n",
    "# 2. Forbered indsamling\n",
    "master_data = []\n",
    "session = requests.Session()\n",
    "session.headers.update({\"User-Agent\": USER_AGENT})\n",
    "\n",
    "lufthavne = df.to_dict('records')\n",
    "aar_liste = range(2001, 2011)\n",
    "\n",
    "print(f\"Starter indsamling af {len(lufthavne) * len(aar_liste)} mulige sider...\")\n",
    "start_tid = time.time()\n",
    "\n",
    "# 3. Kørsel (Løkke over år og lufthavne)\n",
    "count = 0\n",
    "for aar in aar_liste:\n",
    "    print(f\"\\n--- Indsamler for år {aar} ---\")\n",
    "    for lufthavn in lufthavne:\n",
    "        navn = rens_navn(lufthavn['Airport'])\n",
    "        iata = lufthavn['IATA']\n",
    "        \n",
    "        tekst = hent_tekst(session, navn, iata, aar)\n",
    "        \n",
    "        # Tokenizing\n",
    "        tokens = re.sub(r'[^a-z0-9\\s]', '', str(tekst).lower()).split() if tekst else []\n",
    "        \n",
    "        master_data.append({\n",
    "            \"Year\": aar,\n",
    "            \"IATA\": iata,\n",
    "            \"Airport\": navn,\n",
    "            \"Tokens\": tokens\n",
    "        })\n",
    "        \n",
    "        count += 1\n",
    "        if count % 50 == 0:\n",
    "            # Gem fremskridt undervejs\n",
    "            with open(FILNAVN, \"w\", encoding='utf-8') as f:\n",
    "                json.dump(master_data, f, indent=4)\n",
    "            print(f\"Status: {count} rækker færdige... Gemt i fil.\")\n",
    "\n",
    "# Endelig gem\n",
    "with open(FILNAVN, \"w\", encoding='utf-8') as f:\n",
    "    json.dump(master_data, f, indent=4)\n",
    "\n",
    "print(f\"\\nFÆRDIG! Brugte {round((time.time()-start_tid)/60, 1)} minutter.\")"
   ]
