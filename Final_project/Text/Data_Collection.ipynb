    "import pandas as pd\n",
    "import requests\n",
    "import re\n",
    "import json\n",
    "import concurrent.futures\n",
    "import time\n",
    "\n",
    "def hent_smart_tekst(titel, iata, år):\n",
    "    url = \"https://en.wikipedia.org/w/api.php\"\n",
    "    headers = {\"User-Agent\": \"DTU_Aviation_Final_Fix/1.2 (sXXXXXX@dtu.dk)\"}\n",
    "    \n",
    "    # 1. PRØV DET SPECIFIKKE ÅR\n",
    "    params_hist = {\n",
    "        \"action\": \"query\", \"prop\": \"revisions\", \"titles\": titel,\n",
    "        \"redirects\": 1, \"rvlimit\": 1, \"format\": \"json\", \"rvprop\": \"content\",\n",
    "        \"rvdir\": \"older\", \"rvstart\": f\"{år}-12-31T23:59:59Z\"\n",
    "    }\n",
    "    \n",
    "    try:\n",
    "        r = requests.get(url, params=params_hist, headers=headers, timeout=5).json()\n",
    "        pages = r.get(\"query\", {}).get(\"pages\", {})\n",
    "        for pid in pages:\n",
    "            if pid != \"-1\" and \"revisions\" in pages[pid]:\n",
    "                return pages[pid][\"revisions\"][0][\"*\"]\n",
    "        \n",
    "        # 2. HVIS TOM: HENT DEN ALLERFØRSTE VERSION DER FINDES (Backfill)\n",
    "        params_first = {\n",
    "            \"action\": \"query\", \"prop\": \"revisions\", \"titles\": titel,\n",
    "            \"redirects\": 1, \"rvlimit\": 1, \"format\": \"json\", \"rvprop\": \"content\",\n",
    "            \"rvdir\": \"newer\" # Start fra begyndelsen af tiden\n",
    "        }\n",
    "        r_first = requests.get(url, params=params_first, headers=headers, timeout=5).json()\n",
    "        pages_first = r_first.get(\"query\", {}).get(\"pages\", {})\n",
    "        for pid in pages_first:\n",
    "            if pid != \"-1\" and \"revisions\" in pages_first[pid]:\n",
    "                return pages_first[pid][\"revisions\"][0][\"*\"]\n",
    "\n",
    "    except:\n",
    "        pass\n",
    "    return \"\"\n",
    "\n",
    "def lav_tokens(tekst):\n",
    "    t = str(tekst).lower()\n",
    "    t = re.sub(r'[^a-z0-9\\s]', '', t)\n",
    "    return t.split()\n",
    "\n",
    "def proces_række(row, år):\n",
    "    titel = re.sub(r'\\(.*?\\)|\\[.*?\\]', '', row['Airport']).strip().replace('–', '-')\n",
    "    # Hvis titlen fejler, prøver vi med IATA som backup\n",
    "    tekst = hent_smart_tekst(titel, row['IATA'], år)\n",
    "    if not tekst:\n",
    "        tekst = hent_smart_tekst(f\"{row['IATA']} airport\", row['IATA'], år)\n",
    "        \n",
    "    return {\"Year\": år, \"IATA\": row['IATA'], \"Airport\": row['Airport'], \"Tokens\": lav_tokens(tekst)}\n",
    "\n",
    "# --- HOVEDKØRSEL ---\n",
    "print(\"Henter lufthavnsliste og starter tidsrejsen...\")\n",
    "resp = requests.get(\"https://en.wikipedia.org/wiki/List_of_airports_in_the_United_States\", headers={\"User-Agent\":\"Mozilla/5.0\"})\n",
    "df = pd.read_html(resp.text, match=\"IATA\")[0].dropna(subset=['IATA'])\n",
    "\n",
    "# Vi tager hele årrækken nu\n",
    "år_liste = range(2001, 2011)\n",
    "final_data = []\n",
    "\n",
    "# Vi bruger 10 tråde (en gylden middelvej for hastighed og stabilitet)\n",
    "with concurrent.futures.ThreadPoolExecutor(max_workers=10) as executor:\n",
    "    for år in år_liste:\n",
    "        print(f\"Henter data for år {år} (inklusiv historisk backfill)...\")\n",
    "        futures = [executor.submit(proces_række, row, år) for _, row in df.iterrows()]\n",
    "        for future in concurrent.futures.as_completed(futures):\n",
    "            final_data.append(future.result())\n",
    "\n",
    "# Gem resultatet\n",
    "with open(\"AIRPORT_TOKENS_V3_FINAL.json\", \"w\", encoding='utf-8') as f:\n",
    "    json.dump(final_data, f, indent=4)\n",
    "\n",
    "print(f\"\\nSUCCESS! Du har nu {len(final_data)} rækker. Tjek filen nu!\")"
   ]
